# Core
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000

# MongoDB Atlas
# Use your existing Atlas URI, for example:
# mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/freelancehub?retryWrites=true&w=majority&appName=FreelanceHub
MONGODB_URI=

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Optional AI profile co-pilot. Without a key, onboarding still creates a guided starter draft.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Payments
# Cashfree Sandbox can be used for development without live merchant KYC.
PAYMENT_PROVIDER=demo
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
# Optional override. Cashfree payment webhooks normally use the client secret.
CASHFREE_WEBHOOK_SECRET=
CASHFREE_ENV=sandbox
CASHFREE_API_VERSION=2025-01-01
CASHFREE_CURRENCY=INR

# Stripe fallback (optional when PAYMENT_PROVIDER=cashfree)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
PLATFORM_FEE_PERCENT=12

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="FreelanceHub <no-reply@freelancehub.local>"
